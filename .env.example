# Copy this file to .env and fill in your values before running podman-compose / docker-compose.
# This file is read automatically by compose from the project root.

# REQUIRED: JWT signing secret — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret

# PostgreSQL password (also used by the postgres service)
POSTGRES_PASSWORD=chatters

# Optional: comma-separated list of allowed CORS origins
# Leave empty to allow only local/private-network origins
# ALLOWED_ORIGINS=https://your.domain.com,https://app.your.domain.com
